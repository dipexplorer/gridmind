# ─── GridMind — .gitignore ────────────────────────────────────────────────────

# Local configuration — never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Documentation (local only — not in repo) ─────────────────────────────────
docs/
reports/

# ─── GSD Agent configuration (local tooling) ──────────────────────────────────
.agent/
.agents/
guidelines_and_requirement_from_taskinter/
guidelines_and_requirement_from_taskintern/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.pth

# ML model artifacts (large binary files — should use Git LFS or object storage)
backend/ml_models/**/*.pkl
backend/ml_models/**/*.joblib
!backend/ml_models/**/.gitkeep

# SQLite test database
test_gridmind.db

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# ─── Node.js / Frontend ───────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/

# Build output
dist/
build/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/settings.json
*.pem
Thumbs.db

# ─── Docker ───────────────────────────────────────────────────────────────────
# (Docker files are committed, but local overrides are not)
docker-compose.override.yml

# ─── Uploads / Temp ───────────────────────────────────────────────────────────
/tmp/
uploads/
data/
data/APDCL/
